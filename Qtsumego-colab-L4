LETTERS = "ABCDEFGHI"

def coord_to_index(coord: str, board_size: int) -> int:
    return (int(coord[1:]) - 1) * board_size + LETTERS.index(coord[0].upper())

def index_to_coord(index: int, board_size: int) -> str:
    row, col = divmod(index, board_size)
    return f"{LETTERS[col]}{row + 1}"

def get_neighbors(position: int, board_size: int) -> List[int]:
    row, col = divmod(position, board_size)
    neighbors = []
    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:
        nr, nc = row + dr, col + dc
        if 0 <= nr < board_size and 0 <= nc < board_size:
            neighbors.append(nr * board_size + nc)
    return neighbors

class GoBoard:
    EMPTY, BLACK, WHITE = 0, 1, 2

    def __init__(self, board_size: int = 9):
        self.size = board_size
        self.board = np.zeros((board_size, board_size), dtype=int)

    def copy(self):
        newb = GoBoard(self.size)
        newb.board = self.board.copy()
        return newb

    def place_stone(self, coord: str, color: int) -> bool:
        pos = coord_to_index(coord, self.size)
        r, c = divmod(pos, self.size)
        if self.board[r, c] != self.EMPTY:
            return False
        self.board[r, c] = color
        self._remove_captured_groups(3 - color)
        self._remove_captured_groups(color)
        return True

    def _get_group(self, start_pos: int):
        color = self.board[start_pos // self.size, start_pos % self.size]
        if color == self.EMPTY: return [], self.EMPTY
        queue, visited, group = [start_pos], set(), []
        while queue:
            pos = queue.pop()
            if pos in visited: continue
            visited.add(pos)
            r, c = divmod(pos, self.size)
            if self.board[r, c] == color:
                group.append(pos)
                queue.extend(get_neighbors(pos, self.size))
        return group, color

    def _count_liberties(self, group: List[int]) -> int:
        liberties = set()
        for pos in group:
            for n in get_neighbors(pos, self.size):
                r, c = divmod(n, self.size)
                if self.board[r, c] == self.EMPTY:
                    liberties.add(n)
        return len(liberties)

    def _remove_captured_groups(self, color: int):
        visited = set()
        for pos in range(self.size * self.size):
            if pos in visited: continue
            r, c = divmod(pos, self.size)
            if self.board[r, c] == color:
                group, _ = self._get_group(pos)
                visited.update(group)
                if self._count_liberties(group) == 0:
                    for g in group:
                        gr, gc = divmod(g, self.size)
                        self.board[gr, gc] = self.EMPTY

    def get_group_liberties_coords(self, coords: List[str]) -> List[str]:
        liberties = set()
        for coord in coords:
            pos = coord_to_index(coord, self.size)
            for n in get_neighbors(pos, self.size):
                r, c = divmod(n, self.size)
                if self.board[r, c] == self.EMPTY:
                    liberties.add(n)
        return sorted([index_to_coord(idx, self.size) for idx in liberties])

    def get_candidate_moves(self, target_group: List[str], expansion: int = 2) -> List[str]:
        candidates = set()
        for lib in self.get_group_liberties_coords(target_group):
            candidates.add(lib)
        for lib in list(candidates):
            pos = coord_to_index(lib, self.size)
            for n in get_neighbors(pos, self.size):
                r, c = divmod(n, self.size)
                if self.board[r, c] == self.EMPTY:
                    candidates.add(index_to_coord(n, self.size))
        for stone in target_group:
            pos = coord_to_index(stone, self.size)
            for n in get_neighbors(pos, self.size):
                r, c = divmod(n, self.size)
                if self.board[r, c] == self.EMPTY:
                    candidates.add(index_to_coord(n, self.size))
        if expansion >= 2:
            extra = set()
            for c in list(candidates):
                pos = coord_to_index(c, self.size)
                for n in get_neighbors(pos, self.size):
                    r, c_pos = divmod(n, self.size)
                    if self.board[r, c_pos] == self.EMPTY:
                        extra.add(index_to_coord(n, self.size))
            candidates.update(extra)
        return sorted(list(candidates))

    def render(self) -> str:
        symbols = {self.EMPTY: '.', self.BLACK: 'X', self.WHITE: 'O'}
        lines = []
        for r in range(self.size - 1, -1, -1):
            row = "  ".join(symbols[int(self.board[r, c])] for c in range(self.size))
            lines.append(f"{r + 1:2d} {row}")
        lines.append("   " + "  ".join(LETTERS[:self.size]))
        return "\n".join(lines)


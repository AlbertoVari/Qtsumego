class TrainingWidget:
    def __init__(self, moves):
        self.moves = moves
        self.progress = widgets.FloatProgress(value=0, min=0, max=100, description='Progress:')
        self.label = widgets.Label(value="Step 0/0")
        self.status = widgets.Label(value="Inizializzazione...")
        display(widgets.VBox([widgets.HBox([self.progress, self.label]), self.status]))
        self.out = widgets.Output()
        display(self.out)
        with self.out:
            self.fig, self.ax = plt.subplots(figsize=(11, 5.5))

    def update(self, step, total, probs, exp_val):
        self.progress.value = (step + 1) / total * 100
        self.label.value = f"Step {step+1}/{total}"
        best = max(probs, key=probs.get)
        self.status.value = f"Best: {best} ({probs[best]*100:.1f}%) | White Score: {exp_val:.4f}"

        try:
            with self.out:
                clear_output(wait=True)
                vals = [probs.get(m, 0) for m in self.moves]
                self.ax.clear()
                colors = ['gold' if v == max(vals) else 'steelblue' for v in vals]
                self.ax.barh(self.moves, vals, color=colors)
                self.ax.set_xlim(0, 1)
                self.ax.set_title(f"White Score: {exp_val:.4f} | Step {step+1}")
                plt.tight_layout()
                plt.show()
        except Exception:
            pass

    def close(self):
        plt.close(self.fig)

class GPUOptimizer:
    def __init__(self, evaluator):
        self.evaluator = evaluator

    def optimize(self, steps=40, lr=0.05):
        num_params = self.evaluator.born._num_params
        theta = cp.random.uniform(0, np.pi, num_params, dtype=cp.float32)
        widget = TrainingWidget(self.evaluator.candidate_moves)

        beta1, beta2, eps_adam = 0.9, 0.999, 1e-8
        m = cp.zeros_like(theta)
        v = cp.zeros_like(theta)

        shift = cp.pi / 2.0

        for step in range(steps):
            val = self.evaluator.expectation(theta)
            grad = cp.zeros_like(theta)

            for i in range(num_params):
                plus = theta.copy(); plus[i] += shift
                minus = theta.copy(); minus[i] -= shift
                grad[i] = (self.evaluator.expectation(plus) - self.evaluator.expectation(minus)) / 2.0

            m = beta1 * m + (1 - beta1) * grad
            v = beta2 * v + (1 - beta2) * (grad ** 2)
            m_hat = m / (1 - beta1 ** (step + 1))
            v_hat = v / (1 - beta2 ** (step + 1))

            theta += lr * m_hat / (cp.sqrt(v_hat) + eps_adam)
            cp.get_default_memory_pool().free_all_blocks()

            probs = self.evaluator.move_distribution(theta)
            widget.update(step, steps, probs, float(val.get()))

            if step % 5 == 0 or step == steps - 1:
                best_move = max(probs, key=probs.get)
                print(f"🔄 Step {step+1:2d}/{steps} | White Score: {float(val.get()):.4f} | Best: {best_move} ({probs[best_move]*100:.1f}%)")

        widget.close()
        return theta


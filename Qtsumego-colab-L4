def setup_problem():
    board = GoBoard(9)
    for s in ["G2","H2","E3","F3","H3"]:
        board.place_stone(s, GoBoard.BLACK)
    for s in ["C3","D4","E4","F4","G4","H4","G3"]:
        board.place_stone(s, GoBoard.WHITE)
    return board, ["G2","H2","E3","F3","H3"]


class CuQuantumBornTrajectoryCircuit:
    def __init__(self, num_states: int, reps: int = 2, entanglement: str = "linear"):
        self.num_states = num_states
        self.num_qubits = int(np.ceil(np.log2(max(num_states, 2))))
        self.reps = reps

        self.circuit = real_amplitudes(
            num_qubits=self.num_qubits,
            reps=reps,
            entanglement=entanglement,
            insert_barriers=False
        )

        self.parameters = list(self.circuit.parameters)
        self._num_params = len(self.parameters)
        logger.info(f"✅ Circuito: {self._num_params} parametri | {self.num_qubits} qubit | reps={reps} | ent={entanglement}")

    def bind_parameters(self, params: cp.ndarray):
        params_cpu = cp.asnumpy(params).astype(np.float64)
        if len(params_cpu) != self._num_params:
            if len(params_cpu) < self._num_params:
                params_cpu = np.pad(params_cpu, (0, self._num_params - len(params_cpu)))
            else:
                params_cpu = params_cpu[:self._num_params]
        return self.circuit.assign_parameters(params_cpu, inplace=False)

    def probabilities(self, params: cp.ndarray) -> cp.ndarray:
        bound = self.bind_parameters(params)
        sv = Statevector(bound)
        probs = cp.asarray(sv.probabilities())
        return probs / (probs.sum() + 1e-12)


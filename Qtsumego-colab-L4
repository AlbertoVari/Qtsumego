# =============================================================================
# TRAJECTORY EVALUATOR (FIX: Tsumego Logic & Gradient Saturation + DEPTH 4)
# =============================================================================
    def _evaluate_trajectory(self, trajectory) -> float:
        b = self.board.copy()
        colors = [GoBoard.WHITE, GoBoard.BLACK, GoBoard.WHITE, GoBoard.BLACK]

        # Analizziamo la prima mossa del Bianco PRIMA di giocarla
        first_move = trajectory[0]
        first_pos = coord_to_index(first_move, self.board.size)
        r, c = divmod(first_pos, self.board.size)

        # Conta i vicini neri della prima mossa sulla scacchiera INIZIALE
        neighbors = get_neighbors(first_pos, self.board.size)
        black_neighbors = sum(1 for n in neighbors if self.board.board[n // self.board.size, n % self.board.size] == GoBoard.BLACK)

        # REGOLA DEL GO: Penalizza gli attachment pesanti (2+ vicini neri)
        # F2 ha 2 vicini neri (F3, G2) -> Penalità alta
        # E2 ha 1 vicino nero (E3) -> Nessuna penalità (è un placement)
        attachment_penalty = 0.4 if black_neighbors >= 2 else 0.0

        # Simula le 4 mosse
        for i in range(min(len(trajectory), len(colors))):
            move = trajectory[i]
            color = colors[i]
            pos = coord_to_index(move, b.size)
            r, c = divmod(pos, b.size)
            if b.board[r, c] != GoBoard.EMPTY:
                continue
            b.place_stone(move, color)

        # 1. Check if Black group is captured
        black_alive = False
        group_positions = []
        for coord in self.group:
            pos = coord_to_index(coord, b.size)
            r, c = divmod(pos, b.size)
            if b.board[r, c] == GoBoard.BLACK:
                black_alive = True
                group_positions.append(pos)

        if not black_alive:
            return 1.0 - (attachment_penalty * 0.5) # Cattura, ma penalizza se fatta male

        # 2. Count liberties
        libs = len(b.get_group_liberties_coords(self.group))

        # 3. Advanced Eye Space Analysis
        group_set = set(group_positions)
        eye_points = []

        for pos in range(b.size * b.size):
            r, c = divmod(pos, b.size)
            if b.board[r, c] == GoBoard.EMPTY:
                neighbors = get_neighbors(pos, b.size)
                black_neighbors_eye = sum(1 for n in neighbors if n in group_set)
                white_neighbors_eye = sum(1 for n in neighbors if b.board[n // b.size, n % b.size] == GoBoard.WHITE)

                if black_neighbors_eye >= 2 and white_neighbors_eye == 0:
                    eye_points.append(pos)

        # 4. Simulare la risposta del Nero (può fare un occhio?)
        black_can_make_eye = False
        for pos in range(b.size * b.size):
            r, c = divmod(pos, b.size)
            if b.board[r, c] == GoBoard.EMPTY:
                neighbors = get_neighbors(pos, b.size)
                black_neighbors_eye = sum(1 for n in neighbors if b.board[n // b.size, n % b.size] == GoBoard.BLACK)
                white_neighbors_eye = sum(1 for n in neighbors if b.board[n // b.size, n % b.size] == GoBoard.WHITE)
                if black_neighbors_eye >= 3 and white_neighbors_eye == 0:
                    black_can_make_eye = True
                    break

        # 5. Heuristic from WHITE's perspective
        num_eyes = len(eye_points)

        if num_eyes >= 2 and libs >= 2:
            base_score = 0.0
        elif black_can_make_eye:
            base_score = 0.1
        elif num_eyes >= 1 and libs >= 3:
            base_score = 0.3
        elif libs >= 4:
            base_score = 0.5
        else:
            base_score = 0.9

        # Applica la penalità per gli attachment
        final_score = max(0.0, base_score - attachment_penalty)
        return final_score

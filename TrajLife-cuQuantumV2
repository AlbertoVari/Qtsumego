import itertools
import time
from typing import Dict, List, Tuple
import numpy as np
import cupy as cp
from qiskit.circuit.library import RealAmplitudes
from cuquantum.tensornet import contract, CircuitToEinsum

# =========================================================================
# 1. BOARD UTILITIES
# =========================================================================
LETTERS = "ABCDEFGHI"

def coord_to_index(coord: str, board_size: int) -> int:
    col = LETTERS.index(coord[0].upper())
    row = int(coord[1:]) - 1
    return row * board_size + col

def index_to_coord(index: int, board_size: int) -> str:
    row, col = divmod(index, board_size)
    return f"{LETTERS[col]}{row + 1}"

def get_neighbors(position: int, board_size: int) -> List[int]:
    row, col = divmod(position, board_size)
    neighbors = []
    for dr, dc in [(-1, 0), (1, 0), (0, -1), (0, 1)]:
        nr, nc = row + dr, col + dc
        if 0 <= nr < board_size and 0 <= nc < board_size:
            neighbors.append(nr * board_size + nc)
    return neighbors

# =========================================================================
# 2. GO BOARD
# =========================================================================
class GoBoard:
    EMPTY, BLACK, WHITE = 0, 1, 2
    
    def __init__(self, board_size: int = 9):
        self.size = board_size
        self.board = np.zeros((board_size, board_size), dtype=int)
        
    def copy(self) -> "GoBoard":
        newb = GoBoard(self.size)
        newb.board = self.board.copy()
        return newb
        
    def place_stone(self, coord: str, color: int) -> bool:
        pos = coord_to_index(coord, self.size)
        r, c = divmod(pos, self.size)
        if self.board[r, c] != self.EMPTY:
            return False
        self.board[r, c] = color
        self._remove_captured_groups(3 - color)
        self._remove_captured_groups(color)
        return True
        
    def _get_group(self, start_pos: int) -> Tuple[List[int], int]:
        color = self.board[start_pos // self.size, start_pos % self.size]
        if color == self.EMPTY:
            return [], self.EMPTY
        queue = [start_pos]
        visited = set()
        group = []
        while queue:
            pos = queue.pop()
            if pos in visited:
                continue
            visited.add(pos)
            r, c = divmod(pos, self.size)
            if self.board[r, c] == color:
                group.append(pos)
                queue.extend(get_neighbors(pos, self.size))
        return group, color
        
    def _count_liberties(self, group: List[int]) -> int:
        liberties = set()
        for pos in group:
            for n in get_neighbors(pos, self.size):
                r, c = divmod(n, self.size)
                if self.board[r, c] == self.EMPTY:
                    liberties.add(n)
        return len(liberties)
        
    def _remove_captured_groups(self, color: int) -> None:
        visited = set()
        for pos in range(self.size * self.size):
            if pos in visited:
                continue
            r, c = divmod(pos, self.size)
            if self.board[r, c] == color:
                group, _ = self._get_group(pos)
                visited.update(group)
                if self._count_liberties(group) == 0:
                    for g in group:
                        gr, gc = divmod(g, self.size)
                        self.board[gr, gc] = self.EMPTY
                        
    def get_group_liberties(self, coords: List[str]) -> int:
        liberties = set()
        for coord in coords:
            pos = coord_to_index(coord, self.size)
            for n in get_neighbors(pos, self.size):
                r, c = divmod(n, self.size)
                if self.board[r, c] == self.EMPTY:
                    liberties.add(n)
        return len(liberties)
        
    def render(self) -> str:
        symbols = {self.EMPTY: '.', self.BLACK: 'X', self.WHITE: 'O'}
        lines = []
        for r in range(self.size - 1, -1, -1):
            row = " ".join(symbols[int(self.board[r, c])] for c in range(self.size))
            lines.append(f"{r + 1:2d} {row}")
        lines.append("   " + " ".join(LETTERS[:self.size]))
        return "\n".join(lines)

# =========================================================================
# 3. TRAJECTORY GENERATION
# =========================================================================
def generate_trajectories(candidate_moves: List[str], depth: int = 5):
    return list(itertools.product(candidate_moves, repeat=depth))

# =========================================================================
# 4. cuQUANTUM BORN MACHINE
# =========================================================================
class CuQuantumBornTrajectoryCircuit:
    def __init__(self, num_states: int, reps: int = 8, entanglement: str = "full", dtype: str = "complex64"):
        self.num_states = num_states
        self.num_qubits = int(np.ceil(np.log2(max(num_states, 2))))
        self.state_dim = 2 ** self.num_qubits
        self.dtype = dtype
        self.circuit = RealAmplitudes(self.num_qubits, reps=reps, entanglement=entanglement)
        self.parameters = list(self.circuit.parameters)
        
    @property
    def num_parameters(self) -> int:
        return len(self.parameters)
        
    def _bound_circuit(self, params: cp.ndarray):
        # Conversione rapida a CPU solo per l'assegnazione dei parametri in Qiskit
        params_cpu = cp.asnumpy(params).astype(float)
        return self.circuit.assign_parameters(dict(zip(self.parameters, params_cpu)), inplace=False)
        
    def statevector(self, params: cp.ndarray) -> cp.ndarray:
        bound = self._bound_circuit(params)
        converter = CircuitToEinsum(bound, dtype=self.dtype, backend="cupy")
        expression, operands = converter.state_vector()
        state = contract(expression, *operands)
        return state.reshape(-1)
        
    def probabilities(self, params: cp.ndarray) -> cp.ndarray:
        state = self.statevector(params)
        probs = cp.abs(state) ** 2
        return probs / probs.sum()

# =========================================================================
# 5. TRAJECTORY EVALUATOR (GPU-ACCELERATED)
# =========================================================================
class TrajectoryEvaluator:
    def __init__(self, board: GoBoard, group: List[str], candidate_moves: List[str], depth: int = 5, reps: int = 8):
        self.board = board
        self.group = group
        self.candidate_moves = candidate_moves
        self.depth = depth
        self.trajectories = generate_trajectories(candidate_moves, depth)
        self.num_trajectories = len(self.trajectories)
        self.born = CuQuantumBornTrajectoryCircuit(self.num_trajectories, reps=reps)
        
        # Precalcolo deterministico sulla CPU, poi caricamento immediato su GPU
        self.scores_cpu = np.array([self.evaluate_trajectory(t) for t in self.trajectories], dtype=np.float32)
        self.scores_gpu = cp.asarray(self.scores_cpu)
        
        self.move_to_indices = {
            move: cp.asarray([i for i, t in enumerate(self.trajectories) if t[0] == move], dtype=cp.int32)
            for move in self.candidate_moves
        }
        
        print(f"🚀 Configurzione L4 GPU Attiva")
        print(f" - Traiettorie generate: {self.num_trajectories}")
        print(f" - Qubit simulati: {self.born.num_qubits} (Dimensione Stato: {self.born.state_dim})")
        print(f" - Parametri del circuito: {self.born.num_parameters}")
        print(f" - Dispositivo hardware: {cp.cuda.runtime.getDeviceProperties(0)['name'].decode()}")
        
    def evaluate_trajectory(self, trajectory) -> float:
        board = self.board.copy()
        colors = [GoBoard.WHITE if i % 2 == 0 else GoBoard.BLACK for i in range(len(trajectory))]
        for move, color in zip(trajectory, colors):
            board.place_stone(move, color)
        liberties = board.get_group_liberties(self.group)
        if liberties >= 3: return 1.0
        if liberties == 2: return 0.7
        if liberties == 1: return 0.2
        return 0.0
        
    def expectation(self, params: cp.ndarray) -> cp.ndarray:
        probs = self.born.probabilities(params)[:self.num_trajectories]
        return cp.dot(probs, self.scores_gpu)
        
    def move_distribution(self, params: cp.ndarray) -> Dict[str, float]:
        probs = self.born.probabilities(params)[:self.num_trajectories]
        move_probs = {}
        for move, indices in self.move_to_indices.items():
            if indices.size == 0:
                move_probs[move] = 0.0
            else:
                move_probs[move] = float(cp.sum(probs[indices]).get())
        return move_probs

# =========================================================================
# 6. GPU NATIVE GRADIENT OPTIMIZER
# =========================================================================
class GPUOptimizer:
    def __init__(self, evaluator: TrajectoryEvaluator):
        self.evaluator = evaluator
        
    def optimize_gpu(self, steps: int = 60, lr: float = 0.20, eps: float = 1e-2):
        # Inizializzazione dei parametri direttamente in CuPy Array (VRAM)
        theta = cp.random.uniform(0, np.pi, self.evaluator.born.num_parameters, dtype=cp.float32)
        
        print("\n🔹 Avvio Gradient Ascent Nativo su GPU...")
        for step in range(steps):
            current_val = self.evaluator.expectation(theta)
            
            # Calcolo dei gradienti in parallelo simulato su VRAM
            grad = cp.zeros_like(theta)
            for i in range(len(theta)):
                plus = theta.copy()
                minus = theta.copy()
                plus[i] += eps
                minus[i] -= eps
                
                # Calcola la differenza finita direttamente su GPU
                grad[i] = (self.evaluator.expectation(plus) - self.evaluator.expectation(minus)) / (2 * eps)
                
            # Aggiornamento dei pesi (Gradient Ascent per massimizzare l'expectation)
            theta += lr * grad
            
            if step % 10 == 0 or step == steps - 1:
                print(f" Step {step:2d} | Expectation Quantistica: {float(current_val.get()):.4f} | Norm Gradiente: {float(cp.linalg.norm(grad).get()):.4f}")
                
        return theta

# =========================================================================
# 7. SETUP & MAIN
# =========================================================================
def setup_problem():
    board = GoBoard(9)
    black = ["F2", "G2", "H3", "H4"]
    white = ["C3", "E3", "F3", "G3", "G5", "H5", "F6"]
    for s in black: board.place_stone(s, GoBoard.BLACK)
    for s in white: board.place_stone(s, GoBoard.WHITE)
    
    # Set esteso di mosse candidate per sfruttare la GPU L4
    candidates = ["F2", "G2", "H3", "H4"]
    return board, black, candidates

def main():
    start_time = time.time()
    board, group, candidates = setup_problem()
    print("=== SCACCHIERA DI PARTENZA ===")
    print(board.render())
    print("=" * 30 + "\n")
    
    # Inizializzazione dell'analizzatore potenziato (depth=5 e reps=8)
    evaluator = TrajectoryEvaluator(board, group, candidates, depth=5, reps=8)
    
    # Ottimizzazione ad alta velocità
    optimizer = GPUOptimizer(evaluator)
    final_theta = optimizer.optimize_gpu(steps=50)
    
    print("\n" + "=" * 60)
    print(" DISTRIBUZIONE PROBABILISTICA FINALE (BORN MACHINE)")
    print("=" * 60)
    probs = evaluator.move_distribution(final_theta)
    for move, p in sorted(probs.items(), key=lambda x: -x[1]):
        print(f" Mossa {move}: {p:.4f} ({100 * p:.2f}%)")
        
    best_move = max(probs, key=probs.get)
    print("\n" + "=" * 60)
    print(f" 🎯 MIGLIOR MOSSA SUGGERITA: {best_move}")
    print(f" Tempo di esecuzione totale su L4: {time.time() - start_time:.2f} secondi")
    print("=" * 60)

if __name__ == "__main__":
    main()
